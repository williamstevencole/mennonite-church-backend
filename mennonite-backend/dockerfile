FROM node:22-bookworm-slim

# openssl: requerido por Prisma. curl: usado para esperar a Supabase Auth en el arranque.
RUN apt-get update \
  && apt-get install -y --no-install-recommends openssl curl \
  && rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .

# Genera el Prisma Client contra el schema ya copiado.
RUN pnpm exec prisma generate

EXPOSE 3000
CMD ["sh", "-c", "pnpm exec prisma db push && pnpm run db:seed && pnpm run start:dev"]
