# Entorno LOCAL con docker compose. Copia este archivo a .env (ya viene listo por defecto).

PORT=3001
CORS_ORIGIN=http://localhost:4200

# --- Postgres (servicio "db") ---
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=postgres

# --- Prisma (apunta al servicio "db") ---
DATABASE_URL="postgresql://postgres:postgres@db:5432/postgres?schema=public"
DIRECT_URL="postgresql://postgres:postgres@db:5432/postgres?schema=public"

# --- Supabase local (servicio "kong") ---
SUPABASE_URL=http://kong:8000
SUPABASE_ANON_KEY=         # JWT rol anon firmado con JWT_SECRET (ver .env)
SUPABASE_SERVICE_ROLE_KEY= # JWT rol service_role firmado con JWT_SECRET (ver .env)

# Secreto JWT de GoTrue. Debe coincidir con las llaves anon/service_role.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
